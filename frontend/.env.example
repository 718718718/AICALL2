# Environment
NEXT_PUBLIC_NODE_ENV=development

# Backend URL (必須 - Vercelデプロイ時はRenderのURLを設定)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_BACKEND_URL_PROD=https://your-render-app.onrender.com

# API URLs
NEXT_PUBLIC_API_URL_DEV=http://localhost:5000
NEXT_PUBLIC_API_URL_PROD=https://your-render-app.onrender.com

# WebSocket URL (Socket.io接続先 - 本番はRenderのURL)
NEXT_PUBLIC_WS_URL=ws://localhost:5000
# 本番例: NEXT_PUBLIC_WS_URL=wss://aicall2.onrender.com

# App URL (Vercel本番URL)
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app

# Twilio Phone Numbers (for display purposes)
NEXT_PUBLIC_TWILIO_PHONE_DEV=+1xxxxxxxxxx
NEXT_PUBLIC_TWILIO_PHONE_PROD=+1xxxxxxxxxx

# Features
NEXT_PUBLIC_ENABLE_MULTI_TENANT=false