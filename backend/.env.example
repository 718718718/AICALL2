# Environment
NODE_ENV=development

# Server
PORT=5001

# Database
MONGODB_URI=mongodb://localhost:27017/ai-call-system

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key

# Twilio Configuration (Optional - システムはユーザーごとの専用番号を使用)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Fallback Phone Numbers (ユーザーに番号が未設定の場合のフォールバック)
TWILIO_PHONE_NUMBER_DEV=+1xxxxxxxxxx
TWILIO_PHONE_NUMBER_PROD=+1xxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Frontend URL (CORS許可用 - VercelのURLを設定)
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_PROD=https://your-vercel-app.vercel.app

# 開発・テスト環境でサインアップ時のメール認証をスキップ (true/false、未設定時は development/test で有効)
SKIP_EMAIL_VERIFICATION=true

# Webhook URLs
WEBHOOK_BASE_URL_DEV=https://your-ngrok-url.ngrok-free.app
WEBHOOK_BASE_URL_PROD=https://your-render-app.onrender.com
BASE_URL=https://your-ngrok-url.ngrok-free.app
BASE_URL_PROD=https://your-render-app.onrender.com
NGROK_URL=https://your-ngrok-url.ngrok-free.app

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# OpenAI Realtime API (for voice calls)
USE_OPENAI_REALTIME=false
OPENAI_REALTIME_API_KEY=sk-proj-your-realtime-api-key

# Debug mode: Use simplified Media Streams endpoint (no database)
# Set to 'true' for debugging, 'false' for production
USE_SIMPLE_MEDIA_STREAM=false

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket

# Coefont
COEFONT_ACCESS_KEY=your-coefont-key
COEFONT_CLIENT_SECRET=your-coefont-secret