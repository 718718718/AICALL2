# 本番環境設定テンプレート
# このファイルはGitにコミットされる（秘密情報は含まない）
# 実際の本番環境ではRender等のダッシュボードで環境変数を設定する

# Node Environment
NODE_ENV=production

# Server
PORT=5000

# Database (必須 - MongoDB Atlas接続文字列)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Frontend URL (必須 - CORS許可用、VercelのURLを設定)
FRONTEND_URL=https://your-vercel-app.vercel.app
FRONTEND_URL_PROD=https://your-vercel-app.vercel.app

# Webhook / Backend URLs (必須 - RenderのURLを設定)
BASE_URL=https://your-render-app.onrender.com
BASE_URL_PROD=https://your-render-app.onrender.com
WEBHOOK_BASE_URL_PROD=https://your-render-app.onrender.com

# JWT (必須)
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key

# Twilio (必須)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER_PROD=+1xxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# OpenAI (必須)
OPENAI_API_KEY=your-openai-api-key

# Coefont (音声合成を使用する場合)
COE_FONT_KEY=your-coefont-access-key
COE_FONT_CLIENT_SECRET=your-coefont-client-secret
COEFONT_VOICE_ID=your-coefont-voice-id

# OpenAI Realtime (リアルタイム音声を使用する場合)
OPENAI_REALTIME_API_KEY=your-openai-realtime-api-key

# AWS S3 (録音保存を使用する場合)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket

# SMTP (メール認証を使用する場合)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@example.com